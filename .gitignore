# [한글 주석] Git 추적 제외 설정 파일 (.gitignore)

# 파이썬 가상환경 폴더 제외
.venv/
venv/
env/
ENV/

# 노드 및 리액트 의존성 패키지 폴더 제외
node_modules/
jspm_packages/

# 엑스포(Expo) 빌드 캐시 및 설정 제외
.expo/

# VS Code 설정 폴더 제외
.vscode/
.idea/

# 빌드 산출물 및 임시 파일 제외
dist/
build/
out/
*.log

# 운영체제 생성 임시 파일 제외
Thumbs.db
ehthumbs.db
Desktop.ini
desktop.ini
